{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "version", "policies"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "minLength": 1, "maxLength": 80 },
    "policies": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["scope", "windows"],
        "properties": {
          "scope": { "type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$" },
          "windows": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "counter", "limit", "durationSeconds"],
              "properties": {
                "kind": { "type": "string", "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$" },
                "counter": { "enum": ["attempt", "accepted"] },
                "limit": { "type": "integer", "minimum": 1, "maximum": 100000 },
                "durationSeconds": { "type": "integer", "minimum": 60, "maximum": 31536000 }
              }
            }
          }
        }
      }
    }
  }
}
