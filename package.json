{
  "name": "interview-memory-ui",
  "version": "0.1.0",
  "private": true,
  "description": "A modern frontend prototype for anonymous interview experiences and hiring process insights.",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=11 <12"
  },
  "packageManager": "npm@11.9.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:start": "node scripts/start-local-supabase.mjs",
    "db:start:ci": "node scripts/start-local-supabase.mjs --database-only",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset --local",
    "db:lint": "supabase db lint --local --schema api,authorization,core,privacy --level warning --fail-on error",
    "db:test:present": "node scripts/check-database-tests.mjs",
    "db:test": "supabase test db --local",
    "db:types": "node scripts/database-types.mjs generate",
    "db:types:check": "node scripts/database-types.mjs check",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit --incremental false --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contract": "vitest run tests/contract",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run typecheck && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@supabase/ssr": "0.12.3",
    "@supabase/supabase-js": "2.110.7",
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "10.5.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "postcss": "8.5.19",
    "supabase": "2.109.1",
    "tailwindcss": "3.4.17",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
