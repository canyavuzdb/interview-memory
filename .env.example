# Local development: copy this file to .env.local.
# Production: set NEXT_PUBLIC_SITE_URL=https://interview-memory.vercel.app
# in Vercel's Production environment; do not copy .env.local to deployment.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Never expose this value with a NEXT_PUBLIC_ prefix.
SUPABASE_SECRET_KEY=
