# Local development: copy this file to .env.local.
# Production: set NEXT_PUBLIC_SITE_URL=https://interview-memory.vercel.app
# in Vercel's Production environment; do not copy .env.local to deployment.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Never expose this value with a NEXT_PUBLIC_ prefix.
SUPABASE_SECRET_KEY=

# Server-only B06 pseudonym keys. Generate independent 32-byte base64url
# values; never reuse a key across purposes or expose them to the browser.
RESPONDENT_HMAC_ACTIVE_KEY_VERSION=1
RESPONDENT_HMAC_ACTIVE_KEY=
RESPONDENT_HMAC_PREVIOUS_KEY_VERSION=
RESPONDENT_HMAC_PREVIOUS_KEY=
QUOTA_SUBJECT_HMAC_KEY=
IDEMPOTENCY_HMAC_KEY=

# Server-only B07 anonymous submission receipt capability key ring.
SUBMISSION_CAPABILITY_HMAC_ACTIVE_KEY_VERSION=1
SUBMISSION_CAPABILITY_HMAC_ACTIVE_KEY=
SUBMISSION_CAPABILITY_HMAC_PREVIOUS_KEY_VERSION=
SUBMISSION_CAPABILITY_HMAC_PREVIOUS_KEY=
